# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=a-really-really-really-thirty-two-character-long-string-acting-as-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis URL (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# Admin (for /auth/login)
# Generate hash with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
ADMIN_EMAIL=admin@subledger.local
ADMIN_PASSWORD_HASH=<hashed_password>

# Environment
ENVIRONMENT=development
DEBUG=true

RANDOM_HASH=<random_hashed_value>

# DOCKER POSTGRES ENV
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>

# Testing
TEST_DATABASE_URL=postgresql+psycopg://...@db:5432/test_subledger