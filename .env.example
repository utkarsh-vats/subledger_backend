# Connection string the app uses to reach Postgres.
# Inside docker-compose, the hostname is the service name `db`.
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@db:5432/<db_name>

# Redis URL (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# JWT
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<generate-a-long-random-string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin (for /auth/login - Day 2)
# Generate hash with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
ADMIN_EMAIL=admin@subledger.local
ADMIN_PASSWORD_HASH=

# Environment
ENVIRONMENT=development
DEBUG=true

# DOCKER POSTGRES ENV
POSTGRES_DB=<db_name>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
